<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AppLock" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#2196F3</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">#D1E4FF</item>
        <item name="colorOnPrimaryContainer">#001D36</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">#3F51B5</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Status bar and Navigation bar -->
        <item name="android:statusBarColor">#F5F5F5</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">#F5F5F5</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <item name="android:windowBackground">#F5F5F5</item>
    </style>

    <style name="Theme.AppLock.NoActionBar" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
</resources>
