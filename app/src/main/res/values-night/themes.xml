<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark Theme Settings -->
    <style name="Theme.AppLock" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/violet_200</item>
        <item name="colorOnPrimary">#1e1b4b</item>
        <item name="colorPrimaryContainer">#312e81</item>
        <item name="colorOnPrimaryContainer">@color/violet_200</item>

        <item name="android:statusBarColor">#0f172a</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:navigationBarColor">#0f172a</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <item name="android:windowBackground">#0f172a</item>
        <item name="colorSurface">#1e293b</item>
        <item name="colorOnSurface">#f8fafc</item>
        <item name="colorSurfaceVariant">#334155</item>
        <item name="colorOnSurfaceVariant">#f1f5f9</item>
    </style>

    <style name="BoldTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#F9FAFB</item>
    </style>
</resources>
