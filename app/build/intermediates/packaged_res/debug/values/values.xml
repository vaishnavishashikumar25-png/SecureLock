<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">AppLock Pro</string>
    <string name="lock_message">This app is locked. Scan face to enter.</string>
    <string name="request_permissions">Grant Permissions</string>
    <style name="Theme.AppLock" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        
        <item name="colorPrimary">#6200EE</item>
        <item name="colorPrimaryVariant">#3700B3</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">#000000</item>
        
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
    <style name="Theme.AppLock.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>
</resources>